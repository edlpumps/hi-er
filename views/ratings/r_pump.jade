extends layout

include ../common/pump_page

block nav
     +navigation("pump")

block content
    .container
      
      .panel.panel-default.rating_panel
        .panel-heading 
          .heading
           img(src="/images/"+i18n.t("hi_rating_logo", {lng: lang_set}), width="600").hidden-xs
           img(src="/images/"+i18n.t("hi_rating_logo", {lng: lang_set}), style="width:80%").hidden-md.hidden-lg.hidden-sm
             
           h2 #{pump.brand} #{pump.brand ? ' / ' : ''} #{pump.basic_model}
           h4 #{pump.participant.name}
            
        .panel-body
          .row

           .col.col-sm-5.text-center
            .row
              .col.col-sm-6.text-center
                h4 
                  | #{i18n.t("pei",{lng:lang_set})}
                  sub #{pump.configuration == 'bare' || pump.configuration == 'pump_motor' ? i18n.t("cl",{lng:lang_set}) : i18n.t("vl",{lng:lang_set})}
                p.pei_display #{pump.pei.toFixed(2)}
                p.pei_baseline #{i18n.t("baseline",{lng:lang_set})}:  #{pump.pei_baseline.toFixed(2)}
                
              .col.col-sm-6.text-center
                h4 #{i18n.t("energy_rating",{lng:lang_set})}
                p.er_display #{pump.energy_rating}
            .row
              .col.col-sm-12.text-center
               img(src="/images/doe/#{pump_drawing}").hidden-xs
               img(src="/images/doe/#{pump_drawing}", style="width:90%").hidden-md.hidden-lg.hidden-sm
           .col.col-sm-7
             +pump_page_info(pump,true)

                
      
      .panel.panel-default
        .panel-heading
          h1 #{i18n.t("energy_rating_label",{lng:lang_set})}
          +language_switch()
        .panel-body
           .row.solo
            .col.col-lg-12.text-center
              img(src="/labels/#{participant._id}/#{pump._id}/png", style="width:100%; max-width:600px;")

      if pump.revisions && pump.revisions.length > 1
        .panel.panel-default
          .panel-heading
            h2 Data Corrections / Revisions
          .panel-body
            ol 
              each revision in pump.revisions
               if revision.correction
                li
                  span Pump data updated - #{moment(revision.date).format("ll")}.
            
   